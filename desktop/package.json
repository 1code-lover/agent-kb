{
  "name": "northagent-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "NorthAgent desktop client based on Electron + React",
  "author": "NorthAgent",
  "main": "src/main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "build": "node scripts/build-target.js",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.northagent.desktop",
    "productName": "NorthAgent",
    "icon": "resources/icon.png",
    "files": [
      "src/**/*",
      "resources/**/*"
    ],
    "directories": {
      "buildResources": "resources"
    },
    "mac": {
      "icon": "resources/icon.png",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        "nsis"
      ]
    }
  },
  "devDependencies": {
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3"
  }
}
